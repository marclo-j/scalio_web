<nav id="nav" class="glass">
  <div class="nav-inner">
    <a href="/" class="nav-logo" data-cursor-expand>
      <img src="/scalio-logo.webp" alt="Scalio" class="nav-logo-scalio" height="30" width="30" />
    </a>
    <a href="#contacto" class="nav-cta" data-cursor-expand>
      Cotizar <span class="nav-cta-arrow">→</span>
    </a>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 800;
    height: 64px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    opacity: 0;
    transform: translateY(0);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2.5rem;
    gap: 1rem;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--white);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-logo img {
    display: block;
  }

  .nav-cta {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--dark);
    background: var(--yellow);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-weight: 600;
    transition: all 0.3s ease;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .nav-cta:hover {
    background: var(--white);
    transform: scale(1.05);
  }

  .nav-cta-arrow {
    transition: transform 0.3s ease;
  }

  .nav-cta:hover .nav-cta-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .nav-inner {
      padding: 0 1.25rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof gsap !== "undefined") {
      gsap.to("#nav", { opacity: 1, duration: 1, delay: 0.5, ease: "expo.out" });
    }

    let lastY = 0;
    const nav = document.getElementById("nav");
    window.addEventListener("scroll", () => {
      const scrollY = window.scrollY;
      if (scrollY < 100) {
        nav?.style.setProperty("opacity", "1");
        nav?.style.setProperty("transform", "translateY(0)");
        return;
      }
      if (scrollY > lastY + 10) {
        gsap?.to("#nav", { y: -64, opacity: 0, duration: 0.4, ease: "power2.inOut" });
      } else if (scrollY < lastY - 10) {
        gsap?.to("#nav", { y: 0, opacity: 1, duration: 0.4, ease: "power2.out" });
      }
      lastY = scrollY;
    }, { passive: true });
  });
</script>
