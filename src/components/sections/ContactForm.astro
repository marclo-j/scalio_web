<section class="contact-section" id="contacto">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label">Contacto</p>
        <p class="section-subtitle">Hablemos sobre tu proyecto</p>
      </div>
    </div>

    <div class="contact-grid">
      <div class="form-side">
        <form id="contact-form" class="contact-form glass" novalidate>
          <div class="form-group">
            <label for="name">Nombre completo</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Tu nombre"
              required
              autocomplete="name"
            />
          </div>

          <div class="form-group">
            <label for="contact-info">WhatsApp o email</label>
            <input
              type="text"
              id="contact-info"
              name="contact-info"
              placeholder="+51 999 999 999 o tu@email.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="message">Mensaje breve</label>
            <textarea
              id="message"
              name="message"
              placeholder="Describe brevemente qué necesitas..."
              required
              rows="3"></textarea>
          </div>

          <div class="form-footer">
            <button type="submit" class="submit-btn" id="submit-btn">
              <span class="btn-text">Enviar mensaje →</span>
              <span class="btn-loading" aria-hidden="true">Enviando...</span>
            </button>
          </div>

          <div class="form-success" id="form-success" aria-live="polite">
            <div class="success-icon">✓</div>
            <h3>¡Mensaje enviado!</h3>
            <p>
              Te responderemos pronto. También puedes escribirnos
              directamente por WhatsApp.
            </p>
            <a
              href="https://wa.me/51994660039"
              class="wa-btn"
              target="_blank">Abrir WhatsApp →</a
            >
          </div>
        </form>
      </div>

      <div class="info-side">
        <div class="info-block">
          <p class="info-label">Contacto directo</p>
          <div class="info-links">
            <a
              href="https://wa.me/51994660039"
              target="_blank"
              class="info-link"
              data-cursor-expand
            >
              <span class="info-link-icon">💬</span>
              <div>
                <strong>WhatsApp</strong>
                <span>+51 994 660 039</span>
              </div>
              <span class="info-link-arrow">→</span>
            </a>
            <a
              href="mailto:hola@scalio.pe"
              class="info-link"
              data-cursor-expand
            >
              <span class="info-link-icon">✉</span>
              <div>
                <strong>Email</strong>
                <span>hola@scalio.pe</span>
              </div>
              <span class="info-link-arrow">→</span>
            </a>
            <a
              href="https://instagram.com/scalio.studio"
              target="_blank"
              class="info-link"
              data-cursor-expand
            >
              <span class="info-link-icon">◎</span>
              <div>
                <strong>Instagram</strong>
                <span>@scalio.studio</span>
              </div>
              <span class="info-link-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 6rem 0;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-muted);
  }

  .section-subtitle {
    font-size: 0.85rem;
    color: var(--white-muted);
    margin-top: 0.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 5rem;
    align-items: start;
  }

  .contact-form {
    padding: 3rem;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white-muted);
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.875rem 1.125rem;
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 1rem;
    transition:
      border-color 0.3s ease,
      background 0.3s ease;
    outline: none;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.2);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--yellow);
    background: rgba(250, 204, 21, 0.04);
  }

  .form-group input.error,
  .form-group textarea.error {
    border-color: #ef4444;
  }

  .form-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .submit-btn {
    background: var(--yellow);
    color: var(--dark);
    border: none;
    padding: 0.9rem 2.25rem;
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .submit-btn:hover {
    background: var(--white);
    transform: scale(1.04);
  }

  .submit-btn.loading .btn-text {
    opacity: 0;
  }
  .submit-btn.loading .btn-loading {
    opacity: 1;
  }

  .btn-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .form-success {
    position: absolute;
    inset: 0;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .form-success.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .success-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--yellow);
    color: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .form-success h3 {
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .form-success p {
    color: var(--white-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .wa-btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: var(--yellow);
    color: var(--dark);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 700;
    transition: all 0.3s;
  }

  .wa-btn:hover {
    background: var(--white);
  }

  .info-side {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .info-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-muted);
    margin-bottom: 1rem;
  }

  .info-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .info-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--dark-2);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .info-link:hover {
    border-color: rgba(250, 204, 21, 0.3);
    background: rgba(250, 204, 21, 0.04);
    transform: translateX(4px);
  }

  .info-link-icon {
    font-size: 1.1rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(250, 204, 21, 0.1);
    border-radius: 8px;
    flex-shrink: 0;
  }

  .info-link div {
    flex: 1;
  }

  .info-link strong {
    display: block;
    font-size: 0.85rem;
    color: var(--white);
    font-weight: 500;
    margin-bottom: 0.1rem;
  }

  .info-link span:not(.info-link-icon):not(.info-link-arrow) {
    font-size: 0.8rem;
    color: var(--white-muted);
  }

  .info-link-arrow {
    color: var(--white-muted);
    font-size: 0.9rem;
    transition: all 0.3s;
  }

  .info-link:hover .info-link-arrow {
    color: var(--yellow);
    transform: translateX(4px);
  }

  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 768px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .contact-form {
      padding: 2rem;
    }
    .form-footer {
      flex-direction: column;
      align-items: stretch;
    }
    .submit-btn {
      text-align: center;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contact-form");
    const btn = document.getElementById("submit-btn");
    const success = document.getElementById("form-success");

    form?.addEventListener("submit", (e) => {
      e.preventDefault();

      const name = (document.getElementById("name") as HTMLInputElement)?.value;
      const contactInfo = (document.getElementById("contact-info") as HTMLInputElement)?.value;
      const message = (document.getElementById("message") as HTMLTextAreaElement)?.value;

      let valid = true;
      [document.getElementById("name"), document.getElementById("contact-info"), document.getElementById("message")].forEach((el) => {
        if (el && !(el as HTMLInputElement).value.trim()) {
          el.classList.add("error");
          valid = false;
        } else {
          el?.classList.remove("error");
        }
      });

      if (!valid) return;

      btn?.classList.add("loading");

      const waMsg = `Hola Scalio! Mi nombre es ${name}.%0A%0AContacto: ${contactInfo}%0A%0AMensaje: ${message}`;
      const waURL = `https://wa.me/51994660039?text=${waMsg}`;

      setTimeout(() => {
        btn?.classList.remove("loading");
        success?.classList.add("visible");
        window.open(waURL, "_blank");
      }, 800);
    });

    document.querySelectorAll(".form-group input, .form-group textarea").forEach((el) => {
      el.addEventListener("input", () => el.classList.remove("error"));
    });
  });
</script>
