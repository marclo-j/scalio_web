---
import ScrollText from "./ScrollText.astro";
import GlitterWrap from "../GlitterWrap.astro";

const words = ["Scalio", "IA", "Automatización"];
const color = "#F9CC15";

const morph = 0.8;
const hold = 2.5;
const slot = morph + hold;
const cycle = slot * words.length;
const mIn = ((morph / cycle) * 100).toFixed(4);
const mHold = (((morph + hold) / cycle) * 100).toFixed(4);
const mOut = (((2 * morph + hold) / cycle) * 100).toFixed(4);
---

<section class="hero" id="hero">
  <div class="hero-bg-layer"></div>
  <div class="hero-glitter-layer">
    <GlitterWrap />
  </div>

  <img class="hero-logo" src="/scalio-logo.webp" alt="Scalio" />
  <div class="hero-top-right">
    <span class="hero-badge hero-ubication">Lima - Perú</span>
    <a class="hero-badge hero-charlemos"
      href="https://wa.me/51994660039"
      target="_blank"
      rel="noopener">Charlemos
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 7l-10 10" /><path d="M8 7l9 0l0 9" /></svg></a
    >
  </div>

  <div class="hero-capsule">
    <h1 class="hero-morph">
      <span class="morph-spacer">Automatización</span>
      {words.map((word, i) => (
        <span
          class="morph-word"
          style={`--delay:${(slot * i).toFixed(3)}s; --cycle:${cycle}s; color:${color};`}
        >
          {word}
        </span>
      ))}
    </h1>
  </div>

  <div class="hero-carousel">
    <ScrollText compact />
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    overflow: hidden;
  }

  .hero-bg-layer {
    position: absolute;
    inset: 0;
    background: var(--bg);
    z-index: -2;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 5.24vw), 0 100%);
  }

  .hero-glitter-layer {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 5.24vw), 0 100%);
  }

  .hero-logo {
    position: absolute;
    top: 32px;
    left: 32px;
    height: 40px;
    width: auto;
  }

  .hero-badge {
    position: absolute;
    padding: 10px 20px;
    background: transparent;
    color: var(--primary);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: .02em;
    border-radius: 0;
    border: 1px solid var(--primary);
    line-height: 1.2;
    white-space: nowrap;
  }

  .hero-charlemos {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .hero-top-right {
    position: absolute;
    top: 32px;
    right: 32px;
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 2;
  }

  .hero-top-right .hero-badge {
    position: static;
  }

  .hero-carousel {
    position: absolute;
    bottom: -24px;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    z-index: 1;
  }

  .hero-capsule {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border-radius: 9999px;
    padding: 18px 36px;
  }

  .hero-morph {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1.2;
    min-height: 1.2em;
    margin: 0;
    font-family: inherit;
    font-size: clamp(54px, 8.5vw, 108px);
    font-weight: 900;
    letter-spacing: -.04em;
    text-align: center;
  }

  .morph-spacer {
    visibility: hidden;
    white-space: nowrap;
    display: inline-block;
  }

  .morph-word {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    opacity: 0;
    will-change: opacity, filter, transform;
    animation: morphAnim var(--cycle) var(--delay) ease-out infinite;
  }


</style>

<style set:html={`
@keyframes morphAnim {
  0% { opacity: 0; filter: blur(20px); transform: translate(-50%, -50%) scale(0.8); }
  ${mIn}% { opacity: 1; filter: blur(0px); transform: translate(-50%, -50%) scale(1); }
  ${mHold}% { opacity: 1; filter: blur(0px); transform: translate(-50%, -50%) scale(1); }
  ${mOut}%, 100% { opacity: 0; filter: blur(20px); transform: translate(-50%, -50%) scale(1.2); }
}
`} />
