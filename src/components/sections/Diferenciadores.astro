---
import Fondo from "../Fondo.tsx";

const cards = [
  { title: "Enfoque en resultados", icon: "/target-arrow.svg", video: "/videos/accesible.mp4", poster: "/videos/accesible-poster.jpg" },
  { title: "Tecnología moderna", icon: "/bolt.svg", video: "/videos/tecnologia.mp4", poster: "/videos/tecnologia-poster.jpg" },
  { title: "Velocidad de entrega", icon: "/rocket.svg", video: "/videos/velocidad.mp4", poster: "/videos/velocidad-poster.jpg" },
  { title: "Accesible y transparente", icon: "/trending-up.svg", video: "/videos/accesible.mp4", poster: "/videos/accesible-poster.jpg" },
];
---

<section id="resultados">
  <Fondo client:load bgColor="rgba(249, 204, 21, 0.11)" />

  <div class="resultados-inner">
    <div class="section-header">
      <h2 class="resultados-title">¿Por qué deberías elegirnos?</h2>
      <p class="resultados-desc">Combinamos estrategia, tecnología y ejecución para llevar tu negocio al siguiente nivel.</p>
    </div>

    <div class="diff-grid">
      {cards.map((c) => (
        <div class="diff-card">
          <video
            class="card-video js-lazy-video"
            poster={c.poster}
            muted
            loop
            playsinline
            preload="none"
            data-src={c.video}
          ></video>
          <div class="card-overlay"></div>
          <div class="card-content">
            <img src={c.icon} alt="" class="card-icon" />
            <h3>{c.title}</h3>
          </div>
        </div>
      ))}
    </div>
  </div>

</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const videos = document.querySelectorAll(".js-lazy-video");
    if (!videos.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const video = entry.target;
          if (entry.isIntersecting) {
            const src = video.getAttribute("data-src");
            if (src && !video.src) {
              video.src = src;
              video.load();
              video.play().catch(function() {});
            } else if (video.src) {
              video.play().catch(function() {});
            }
          } else {
            video.pause();
          }
        });
      },
      {
        rootMargin: "200px",
        threshold: 0.1,
      }
    );

    videos.forEach(function(video) {
      observer.observe(video);
    });
  });
</script>

<style>
  #resultados {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 75px 0;
    overflow: hidden;
  }

  #resultados > :global(.fondo-container) {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .resultados-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 0 24px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .resultados-title {
    font-size: clamp(48.6px, 7.65vw, 97.2px);
    font-weight: 900;
    color: #F9CC15;
    line-height: 1.1;
    letter-spacing: -.04em;
    margin-bottom: 16px;
  }

  .resultados-desc {
    font-size: 20px;
    font-weight: 600;
    color: #F9CC15;
    letter-spacing: .02em;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .diff-card {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 682px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    background: #000;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.8) 100%);
  }

  .card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
    padding: 24px;
  }

  .card-icon {
    width: 64px;
    height: 64px;
    padding: 5px;
    background: #F9CC15;
    border-radius: 50%;
    object-fit: contain;
  }

  .diff-card h3 {
    font-size: 26px;
    font-weight: 700;
    color: #F9CC15;
    letter-spacing: -0.01em;
  }

  @media (max-width: 640px) {
    .diff-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .diff-card {
      padding: 28px 20px;
    }
  }
</style>
