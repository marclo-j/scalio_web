  }

  @media (max-width: 640px) {
    .carousel {
      max-width: 100%;
      gap: 0;
    }

    .carousel-viewport {
      overflow: hidden;
    }

    .work-card {
      flex: 0 0 100%;
      min-height: 420px;
      border-radius: 20px !important;
      cursor: pointer;
    }

    .work-card.card-left,
    .work-card.card-center,
    .work-card.card-right {
      opacity: 1;
      mask-image: none;
      -webkit-mask-image: none;
    }

    .carousel-arrow {
      width: 32px;
