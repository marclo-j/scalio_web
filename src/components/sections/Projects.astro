<section id="proyectos" class="projects">
  <div class="container">
    <div class="section-header">
      <div>
        <h2 class="section-title">Trabajo seleccionado</h2>
        <p class="section-subtitle">Proyectos que generan resultados reales</p>
      </div>
    </div>

    <div class="carousel">
      <button class="carousel-arrow carousel-prev" aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="carousel-viewport">
        <div class="carousel-track">
          <article class="work-card" data-cursor-text="Ver proyecto" data-title="Codesotec" data-url="https://codesotec-web-chi.vercel.app/">
            <img src="/images/projects/codesotec.jpg" alt="Codesotec" class="card-img" loading="eager" />
            <div class="card-overlay">
              <div class="card-tags">
                <span class="tag">Rediseño web</span>
                <span class="tag">Automatización</span>
                <span class="tag">n8n</span>
              </div>
              <a href="https://codesotec-web-chi.vercel.app/" target="_blank" rel="noopener" class="card-link mobile-only">
                Ver proyecto <span class="arrow">→</span>
              </a>
            </div>
          </article>

          <article class="work-card" data-cursor-text="Ver proyecto" data-title="Gotas de Esperanza" data-url="https://ong-web-weld.vercel.app/">
            <img src="/images/projects/gotas-esperanza.jpg" alt="Gotas de Esperanza" class="card-img" loading="eager" />
            <div class="card-overlay">
              <div class="card-tags">
                <span class="tag">Rediseño web</span>
                <span class="tag">SEO</span>
                <span class="tag">Escalabilidad</span>
              </div>
              <a href="https://ong-web-weld.vercel.app/" target="_blank" rel="noopener" class="card-link mobile-only">
                Ver proyecto <span class="arrow">→</span>
              </a>
            </div>
          </article>
        </div>
      </div>

      <button class="carousel-arrow carousel-next" aria-label="Siguiente">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="carousel-info">
      <h3 class="carousel-title">Codesotec</h3>
    </div>
  </div>
</section>


<script>
  import gsap from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const track = document.querySelector<HTMLElement>(".carousel-track");
    const prevBtn = document.querySelector<HTMLButtonElement>(".carousel-prev");
    const nextBtn = document.querySelector<HTMLButtonElement>(".carousel-next");
    const titleEl = document.querySelector<HTMLElement>(".carousel-title");
    
    if (!track || !prevBtn || !nextBtn || !titleEl) return;

    const cards = Array.from(track.querySelectorAll<HTMLElement>(".work-card"));
    if (cards.length === 0) return;

    const totalCards = cards.length;
    let currentIndex = 0;
    let isAnimating = false;
    const isMobile = window.innerWidth <= 640;

    function getCardWidth() {
      const card = cards[0];
      if (!card) return 0;
      const gap = parseFloat(getComputedStyle(track).gap) || 0;
      return card.offsetWidth + gap;
    }

    function getInitialOffset() {
      const cardWidth = cards[0]?.offsetWidth || 0;
      return (track.clientWidth - cardWidth) / 2;
    }

    function goToCard(index: number, animate = true) {
      if (isAnimating && animate) return;
      if (index < 0 || index >= totalCards) return;
      
      const cardWidth = getCardWidth();
      const initialOffset = getInitialOffset();
      const targetX = initialOffset - (index * cardWidth);
      
      currentIndex = index;
      
      if (animate) {
        isAnimating = true;
        
        const tl = gsap.timeline({
          onComplete: () => { isAnimating = false; }
        });

        tl.to(titleEl, {
          opacity: 0, y: 5,
          duration: 0.1, ease: "power2.in"
        });

        tl.to(track, {
          x: targetX,
          duration: 0.45,
          ease: "expo.inOut",
          onUpdate: updateCardStates
        }, "-=0.05");

        tl.call(() => updateInfo());

        tl.fromTo(titleEl,
          { opacity: 0, y: -5 },
          { opacity: 1, y: 0, duration: 0.18, ease: "power2.out" }
        );
      } else {
        gsap.set(track, { x: targetX });
        updateCardStates();
        updateInfo();
      }
    }

    // Navigation - simple, no wrapping
    prevBtn.addEventListener("click", () => {
      if (currentIndex > 0) goToCard(currentIndex - 1);
    });

    nextBtn.addEventListener("click", () => {
      if (currentIndex < totalCards - 1) goToCard(currentIndex + 1);
    });

    // Hover effects
    cards.forEach((card) => {
      const url = card.dataset.url;

      // Mobile: always show overlay
      if (isMobile) {
        const overlay = card.querySelector(".card-overlay") as HTMLElement;
        if (overlay) {
          gsap.set(overlay, { opacity: 1, y: 0 });
        }
        if (url) {
          card.style.cursor = "pointer";
          card.addEventListener("click", (e) => {
            if (!(e.target as HTMLElement).closest('.card-link')) {
              window.open(url, "_blank");
            }
          });
        }
      }

      // Desktop hover
      card.addEventListener("mouseenter", () => {
        if (card.classList.contains("card-center") && !isMobile) {
          gsap.to(card, {
            scale: 1.03, duration: 0.2, ease: "power2.out",
            boxShadow: "0 15px 40px rgba(0, 0, 0, 0.4)"
          });
          const img = card.querySelector("img");
          if (img) gsap.to(img, { scale: 1.08, duration: 0.25, ease: "power2.out" });
          
          const overlay = card.querySelector(".card-overlay") as HTMLElement;
          if (overlay) {
            gsap.to(overlay, { opacity: 1, y: 0, duration: 0.2, ease: "power2.out" });
          }
          
          if (url) {
            card.style.cursor = "pointer";
            card.onclick = () => window.open(url, "_blank");
          }
        }
      });
      
      card.addEventListener("mouseleave", () => {
        if (card.classList.contains("card-center") && !isMobile) {
          gsap.to(card, {
            scale: 1, duration: 0.2, ease: "power2.out",
            boxShadow: "0 0px 0px rgba(0, 0, 0, 0)"
          });
          const img = card.querySelector("img");
          if (img) gsap.to(img, { scale: 1, x: 0, y: 0, duration: 0.25, ease: "power2.out" });
          
          const overlay = card.querySelector(".card-overlay") as HTMLElement;
          if (overlay) {
            gsap.to(overlay, { opacity: 0, y: 10, duration: 0.15, ease: "power2.in" });
          }
        }
      });
      
      // Parallax
      if (!isMobile) {
        card.addEventListener("mousemove", (e) => {
          if (!card.classList.contains("card-center")) return;
          const img = card.querySelector("img");
          if (!img) return;
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          gsap.to(img, { x: x * 12, y: y * 12, duration: 0.25, ease: "power2.out" });
        });
      }
    });

    // Button effects
    [prevBtn, nextBtn].forEach((btn) => {
      btn.addEventListener("mouseenter", () => gsap.to(btn, { scale: 1.1, duration: 0.15, ease: "power2.out" }));
      btn.addEventListener("mouseleave", () => gsap.to(btn, { scale: 1, duration: 0.15, ease: "power2.out" }));
      btn.addEventListener("mousedown", () => gsap.to(btn, { scale: 0.95, duration: 0.08, ease: "power2.out" }));
      btn.addEventListener("mouseup", () => gsap.to(btn, { scale: 1.1, duration: 0.1, ease: "power2.out" }));
    });

    function updateInfo() {
      const card = cards[currentIndex];
      if (card && titleEl) {
        titleEl.textContent = card.dataset.title || "";
      }
    }

    function updateCardStates() {
      cards.forEach((card, i) => {
        card.classList.remove("card-left", "card-center", "card-right");
        
        if (i === currentIndex) {
          card.classList.add("card-center");
          gsap.to(card, {
            filter: "blur(0px) brightness(1.1) saturate(1.1)",
            scale: 1, opacity: 1, duration: 0.3, ease: "power2.inOut"
          });
        } else if (i < currentIndex) {
          card.classList.add("card-left");
          gsap.to(card, {
            filter: "blur(2px) brightness(0.7) saturate(0.8)",
            scale: 0.95, opacity: 0.7, duration: 0.3, ease: "power2.inOut"
          });
        } else {
          card.classList.add("card-right");
          gsap.to(card, {
            filter: "blur(2px) brightness(0.7) saturate(0.8)",
            scale: 0.95, opacity: 0.7, duration: 0.3, ease: "power2.inOut"
          });
        }
      });
    }

    function animateInitialLoad() {
      gsap.from(cards, {
        opacity: 0, y: 30, duration: 0.5,
        stagger: 0.05, ease: "power2.out", delay: 0.1
      });
      gsap.from(titleEl, {
        opacity: 0, y: 20, duration: 0.4,
        ease: "power2.out", delay: 0.2
      });
    }

    setTimeout(() => {
      goToCard(0, false);
      animateInitialLoad();
    }, 0);
  });
</script>

<style>
