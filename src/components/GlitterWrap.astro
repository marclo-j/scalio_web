<div class="glitter-wrap">
  <canvas class="glitter-canvas" id="glitterCanvas"></canvas>
</div>

<script>
  (function () {
    const container = document.querySelector(".glitter-wrap")
    const canvas = document.getElementById("glitterCanvas")
    if (!container || !canvas) return
    const ctx = canvas.getContext("2d")
    if (!ctx) return

    const DPR = Math.min(window.devicePixelRatio || 1, 2)
    let W = 0, H = 0

    const parsec = (input) => {
      if (!input) return [255, 255, 255, 1]
      const s = input.trim()
      if (s.startsWith("#")) {
        let hex = s.slice(1)
        if (hex.length === 3) hex = hex.split("").map((c) => c + c).join("")
        const num = parseInt(hex, 16)
        return [(num >> 16) & 255, (num >> 8) & 255, num & 255, 1]
      }
      return [255, 255, 255, 1]
    }

    const c1 = parsec("#F9CC15")
    const c2 = parsec("#F9CC15")
    const c3 = parsec("#F9CC15")
    const rgbStrs = [
      `rgb(${c1[0]},${c1[1]},${c1[2]})`,
      `rgb(${c2[0]},${c2[1]},${c2[2]})`,
      `rgb(${c3[0]},${c3[1]},${c3[2]})`,
    ]

    const stepZ = 3 * 0.0008
    const focalDepth = 0.13
    const starScale = 10 * 0.15
    const count = 300

    const stars = []
    const resetStar = (s, initial) => {
      const angle = Math.random() * Math.PI * 2
      const radius = (0.2 + Math.random() * 0.8) * 6.67
      s.x = Math.cos(angle) * radius
      s.y = Math.sin(angle) * radius
      s.z = initial ? Math.random() : 1.0
      s.px = NaN
      s.py = NaN
      s.seed = Math.random() * 1000
      s.vmul = 0.6 + Math.random() * 0.8
      s.colorIdx = Math.floor(Math.random() * 3)
    }
    for (let i = 0; i < count; i++) {
      const s = { x: 0, y: 0, z: 0, px: NaN, py: NaN, seed: 0, vmul: 1, colorIdx: 0 }
      resetStar(s, true)
      stars.push(s)
    }

    const resize = () => {
      const w = Math.max(1, container.clientWidth || 600)
      const h = Math.max(1, container.clientHeight || 400)
      if (W === w && H === h) return
      W = w; H = h
      canvas.width = Math.floor(w * DPR)
      canvas.height = Math.floor(h * DPR)
      canvas.style.width = w + "px"
      canvas.style.height = h + "px"
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0)
    }

    const ro = new ResizeObserver(resize)
    ro.observe(container)
    resize()

    let lastT = 0
    let elapsed = 0

    const draw = (ts) => {
      if (lastT === 0) lastT = ts
      const deltaSec = Math.min(0.1, (ts - lastT) / 1000)
      lastT = ts
      const dt = deltaSec * 60

      const cx = W / 2
      const cy = H / 2
      const projScale = Math.min(W, H) * 0.9

      ctx.globalCompositeOperation = "destination-out"
      ctx.fillStyle = "rgba(0,0,0,0.2)"
      ctx.fillRect(0, 0, W, H)

      ctx.globalCompositeOperation = "lighter"

      for (let i = 0; i < stars.length; i++) {
        const s = stars[i]
        s.z -= stepZ * s.vmul * dt
        if (s.z <= focalDepth) { resetStar(s, false); continue }

        const persp = focalDepth / Math.max(s.z, 0.0001)
        const sx = cx + s.x * persp * projScale
        const sy = cy + s.y * persp * projScale

        if (sx < -20 || sx > W + 20 || sy < -20 || sy > H + 20) {
          resetStar(s, false)
          continue
        }

        const lifeT = 1 - s.z
        const a = Math.min(1, lifeT * 0.9 + 0.05) * 0.8
        const sizePersp = Math.min(2.5, (focalDepth / Math.max(s.z, 0.0001)) * 0.6)
        const r = Math.max(0.25, starScale * (0.4 + sizePersp))
        const colStr = rgbStrs[s.colorIdx]

        if (!Number.isNaN(s.px) && !Number.isNaN(s.py)) {
          ctx.globalAlpha = a * 0.5
          ctx.strokeStyle = colStr
          ctx.lineWidth = Math.max(0.4, r * 0.4)
          ctx.beginPath()
          ctx.moveTo(s.px, s.py)
          ctx.lineTo(sx, sy)
          ctx.stroke()
        }

        ctx.globalAlpha = a
        ctx.fillStyle = colStr
        ctx.fillRect(sx - r, sy - r, r * 2, r * 2)

        s.px = sx
        s.py = sy
      }

      ctx.globalAlpha = 1
      ctx.globalCompositeOperation = "source-over"
      elapsed += deltaSec
      requestAnimationFrame(draw)
    }

    requestAnimationFrame(draw)
  })()
</script>

<style>
  .glitter-wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .glitter-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
