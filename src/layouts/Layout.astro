---
import "@fontsource-variable/figtree/wght.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  schema?: object;
}

const {
  title = "Scalio | Páginas web y automatización para negocios en Perú",
  description = "Agencia digital en Lima, Perú. Creamos páginas web que convierten visitantes en clientes y automatizamos tareas repetitivas para tu negocio.",
  image = "/og-image.jpg",
  canonical,
  noindex = false,
  schema,
} = Astro.props;

const siteUrl = "https://scalio-web.vercel.app";
const canonicalUrl = canonical
  ? `${siteUrl}${canonical}`
  : `${siteUrl}${Astro.url.pathname}`;
const ogImage = image.startsWith("http") ? image : `${siteUrl}${image}`;

// Schema.org por defecto: Organization + LocalBusiness + WebSite + FAQPage
const defaultSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: "Scalio",
      url: siteUrl,
      logo: {
        "@type": "ImageObject",
        url: `${siteUrl}/logo.png`,
        width: 512,
        height: 512,
      },
      sameAs: [
        "https://www.linkedin.com/company/scalio",
        "https://www.instagram.com/scalio.pe",
      ],
      description:
        "Agencia digital especializada en desarrollo web y automatización de procesos para negocios en Perú.",
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#localbusiness`,
      name: "Scalio - Agencia Digital",
      image: `${siteUrl}/og-image.jpg`,
      url: siteUrl,
      email: "hola@scalio.pe",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Lima",
        addressLocality: "Lima",
        addressRegion: "Lima",
        postalCode: "15001",
        addressCountry: "PE",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: -12.0464,
        longitude: -77.0428,
      },
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          opens: "09:00",
          closes: "18:00",
        },
      ],
      priceRange: "$$",
      areaServed: {
        "@type": "Country",
        name: "Perú",
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "Scalio",
      publisher: {
        "@id": `${siteUrl}/#organization`,
      },
    },
  ],
};

const finalSchema = schema || defaultSchema;
---

<!doctype html>
<html lang="es-PE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ═══════════════════════════════════════════════ -->
    <!-- SEO TÉCNICO — NUEVO (no toca tu diseño)       -->
    <!-- ═══════════════════════════════════════════════ -->

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Robots -->
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta
          name="robots"
          content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
        />
      )
    }

    <!-- Título y descripción optimizados -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Scalio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Seguridad y performance -->
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark" />

    <!-- Preconnect para velocidad -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/scalio-logo.webp" />

    <!-- Schema.org JSON-LD (lo que faltaba) -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />

    <!-- ═══════════════════════════════════════════════ -->
    <!-- TU DISEÑO ORIGINAL — SIN CAMBIOS               -->
    <!-- ═══════════════════════════════════════════════ -->

    <!-- Google Fonts: Coloca aquí tu fuente manualmente -->
    <!-- <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=TU_FUENTE" rel="stylesheet" /> -->

    <!-- GSAP CDN -->
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js"
    ></script>

    <!-- Slot para head adicional (breadcrumbs, schemas extra, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════════ */
  /* TU CSS ORIGINAL — SIN NINGÚN CAMBIO             */
  /* ═══════════════════════════════════════════════ */

  /* ─── CSS Variables ─────────────────────────── */
  :root {
    --yellow: #facc15;
    --yellow-dim: #ca9e00;
    --dark: #0a0a0a;
    --dark-2: #111111;
    --dark-3: #1a1a1a;
    --white: #ffffff;
    --white-muted: rgba(255, 255, 255, 0.6);
    --white-dim: rgba(255, 255, 255, 0.08);
    --border: rgba(255, 255, 255, 0.1);
    --glass-bg: rgba(10, 10, 10, 0.6);
    --glass-border: rgba(250, 204, 21, 0.15);

    /* Fuente: reemplaza con tu Google Font */
    --font-sans: "Figtree Variable", sans-serif;
    --font-display: "Georgia", serif;

    /* Easing */
    --ease-brand: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ─── Reset & Base ──────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
    background-color: var(--dark);
  }

  body {
    font-family: var(--font-sans);
    color: var(--white);
    background-color: var(--dark);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ─── Scrollbar ─────────────────────────────── */
  ::-webkit-scrollbar {
    width: 4px;
  }
  ::-webkit-scrollbar-track {
    background: var(--dark);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--yellow);
    border-radius: 2px;
  }

  /* ─── Selection ─────────────────────────────── */
  ::selection {
    background: var(--yellow);
    color: var(--dark);
  }

  /* ─── Typography ─────────────────────────────── */
  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 7rem);
  }
  h2 {
    font-size: clamp(2rem, 5vw, 4.5rem);
  }
  h3 {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
  }
  p {
    line-height: 1.7;
    color: var(--white-muted);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  /* ─── Page Transition Overlay ─────────────────── */
  #page-overlay {
    position: fixed;
    inset: 0;
    background: var(--yellow);
    z-index: 9999;
    transform: scaleY(0);
    transform-origin: bottom;
    pointer-events: none;
  }

  /* ─── Cursor ─────────────────────────────────── */
  .cursor {
    position: fixed;
    width: 10px;
    height: 10px;
    background: var(--yellow);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9000;
    transform: translate(-50%, -50%);
    transition:
      transform 0.1s ease,
      width 0.3s ease,
      height 0.3s ease,
      opacity 0.3s;
    mix-blend-mode: difference;
  }

  .cursor-ring {
    position: fixed;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(250, 204, 21, 0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 8999;
    transform: translate(-50%, -50%);
    transition: all 0.15s ease;
  }

  .cursor--text {
    width: auto !important;
    height: auto !important;
    background: var(--yellow);
    color: var(--dark);
    padding: 0.5rem 1rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    mix-blend-mode: normal;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Glass ──────────────────────────────────── */
  .glass {
    background: var(--glass-bg);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid var(--glass-border);
  }

  /* ─── Utilities ──────────────────────────────── */
  .container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.25rem;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* ─── Reveal Animations (DESACTIVADAS) ───────────── */
  .reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-left {
    opacity: 1;
    transform: translateX(0);
  }

  .reveal-right {
    opacity: 1;
    transform: translateX(0);
  }

  .split-char {
    display: inline-block;
    overflow: hidden;
  }

  /* ─── Shared Button Styles ──────────────────────── */
  .btn-primary {
    padding: 0.9rem 2.25rem;
    background: var(--yellow);
    color: var(--dark);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 100px;
    transition: all 0.3s ease;
    display: inline-block;
    text-align: center;
  }

  .btn-primary:hover {
    background: var(--white);
    transform: translateY(-2px);
  }

  .btn-ghost {
    padding: 0.9rem 2.25rem;
    border: 1px solid var(--border);
    color: var(--white-muted);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 100px;
    transition: all 0.3s ease;
    display: inline-block;
    text-align: center;
  }

  .btn-ghost:hover {
    border-color: var(--yellow);
    color: var(--yellow);
  }

  /* ═══════════════════════════════════════════════ */
  /* SEO: ACCESIBILIDAD EXTRA (no afecta diseño)    */
  /* ═══════════════════════════════════════════════ */

  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: var(--yellow);
    color: var(--dark);
    padding: 8px 16px;
    z-index: 10000;
    font-weight: 600;
    font-size: 0.9rem;
    transition: top 0.3s;
  }
  .skip-link:focus {
    top: 0;
  }

  :focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }
</style>
