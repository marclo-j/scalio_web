---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import ChatWidget from "../components/ChatWidget.astro";

import Hero from "../components/sections/Hero.astro";
import Services from "../components/sections/Services.astro";
import Diferenciadores from "../components/sections/Diferenciadores.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import CTA from "../components/sections/CTA.astro";
import { BackgroundGradientAnimation } from "../ui/background-gradient-animation";

const faqSchema = null; // removed FAQ section
---

<Layout
  title="Scalio — Transformación Digital para tu Negocio"
  description="Agencia digital en Lima, Perú. Creamos páginas web que convierten visitantes en clientes y automatizamos tareas repetitivas para tu negocio."
  canonical="/"
>
  <div class="scroll-progress" id="scrollProgress"></div>

  <nav class="nav-dots" id="navDots" aria-label="Navegación de secciones">
    <button class="nav-dot active" data-target="hero" aria-label="Inicio"></button>
    <button class="nav-dot" data-target="servicios" aria-label="Servicios"></button>
    <button class="nav-dot" data-target="testimonios" aria-label="Testimonios"></button>
    <button class="nav-dot" data-target="resultados" aria-label="Resultados"></button>
    <button class="nav-dot" data-target="cta" aria-label="CTA"></button>
    <button class="nav-dot" data-target="contacto-footer" aria-label="Contacto"></button>
  </nav>

  <BackgroundGradientAnimation client:load>
    <Hero />
    <Services />
    <Diferenciadores />
    <Testimonials />
    <CTA />
    <Footer />
  </BackgroundGradientAnimation>

  <ChatWidget />

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      function initGSAP() {
        if (typeof gsap === "undefined" || typeof ScrollTrigger === "undefined") return false;
        try {
          gsap.registerPlugin(ScrollTrigger);

          // Scroll progress bar
          gsap.to("#scrollProgress", {
            scaleX: 1,
            ease: "none",
            scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: 1 }
          });

          // Nav dots - active state on scroll
          const sections = ["hero", "servicios", "testimonios", "resultados", "cta", "contacto-footer"];
          const dots = document.querySelectorAll(".nav-dot");

          sections.forEach((id, i) => {
            ScrollTrigger.create({
              trigger: "#" + id,
              start: "top center",
              end: "bottom center",
              onEnter: () => setActive(i),
              onEnterBack: () => setActive(i)
            });
          });

          function setActive(i) {
            dots.forEach(d => d.classList.remove("active"));
            dots[i]?.classList.add("active");
          }

          dots.forEach((dot, i) => {
            dot.addEventListener("click", () => {
              const el = document.getElementById(sections[i]);
              if (el) {
                const top = el.getBoundingClientRect().top + window.scrollY;
                window.scrollTo({ top, behavior: "smooth" });
              }
            });
          });

          // Hero reveal
          gsap.utils.toArray(".hero .reveal").forEach((el, i) => {
            gsap.fromTo(el,
              { y: 50, opacity: 0 },
              {
                y: 0, opacity: 1, duration: 1, ease: "power3.out",
                delay: 0.1 + i * 0.12,
                scrollTrigger: {
                  trigger: ".hero",
                  start: "top 80%",
                  toggleActions: "play none none none"
                }
              }
            );
          });

          // Services section fade-in
          gsap.fromTo(".services-reveal-container",
            { y: 40, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 1, ease: "power3.out",
              scrollTrigger: {
                trigger: ".services-section",
                start: "top 85%",
                toggleActions: "play none none none"
              }
            }
          );

          // Diff cards stagger
          gsap.utils.toArray(".diff-card").forEach((el, i) => {
            gsap.fromTo(el,
              { y: 40, opacity: 0, scale: 0.92 },
              {
                y: 0, opacity: 1, scale: 1, duration: 0.7, ease: "power3.out",
                delay: i * 0.1,
                scrollTrigger: {
                  trigger: ".diff-grid",
                  start: "top 80%",
                  toggleActions: "play none none none"
                }
              }
            );
          });

          // Testimonials stagger
          gsap.utils.toArray(".testimonial-card").forEach((el, i) => {
            gsap.fromTo(el,
              { y: 50, opacity: 0 },
              {
                y: 0, opacity: 1, duration: 0.8, ease: "power2.out",
                delay: i * 0.15,
                scrollTrigger: {
                  trigger: el,
                  start: "top 88%",
                  toggleActions: "play none none none"
                }
              }
            );
          });

          // CTA section fade-in
          gsap.fromTo(".cta-inner",
            { y: 40, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 1, ease: "power3.out",
              scrollTrigger: {
                trigger: ".cta-section",
                start: "top 85%",
                toggleActions: "play none none none"
              }
            }
          );

          // ScrollTrigger refresh after WebGL/React components settle
          setTimeout(() => ScrollTrigger.refresh(), 1500);
          setTimeout(() => ScrollTrigger.refresh(), 3000);

          return true;
        } catch (e) {
          return false;
        }
      }

      if (!initGSAP()) {
        let attempts = 0;
        function retry() {
          attempts++;
          if (initGSAP()) return;
          if (attempts < 30) requestAnimationFrame(retry);
        }
        requestAnimationFrame(retry);
      }
    });
  </script>
</Layout>
