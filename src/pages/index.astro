---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";

import Hero from "../components/sections/Hero.astro";
import TrustBar from "../components/sections/TrustBar.astro";
import Services from "../components/sections/Services.astro";
import Diferenciadores from "../components/sections/Diferenciadores.astro";
import Projects from "../components/sections/Projects.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import FAQ from "../components/sections/FAQ.astro";
import ContactForm from "../components/sections/ContactForm.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Cuánto cuesta una página web en Perú?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "El costo varía según complejidad. Ofrecemos desarrollo web estratégico incluyendo diseño responsive, SEO básico y optimización para conversiones. Una landing page profesional puede costar desde S/500–S/800, mientras que un e-commerce completo puede ir desde S/2,500. Solicita tu cotización personalizada sin compromiso.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cuánto tiempo tardan en entregar una página web?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Una landing page o web corporativa básica toma entre 2 y 3 semanas. Proyectos más complejos como e-commerce o plataformas personalizadas pueden tomar de 4 a 8 semanas. Siempre entregamos con fecha exacta y mantenemos comunicación constante durante el proceso.",
      },
    },
    {
      "@type": "Question",
      name: "¿Qué incluye el desarrollo web en Scalio?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nuestro desarrollo web incluye: diseño UX/UI estratégico orientado a conversiones, desarrollo con tecnología moderna, SEO técnico básico, velocidad de carga optimizada, responsive para todos los dispositivos, integración con WhatsApp Business, formularios de contacto, Google Analytics configurado y 30 días de soporte post-lanzamiento.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cómo funciona la automatización de WhatsApp para negocios?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Implementamos respuestas automáticas inteligentes en WhatsApp Business que atienden a tus clientes 24/7: mensajes de bienvenida personalizados, respuestas a preguntas frecuentes, captura de datos de leads, envío automático de catálogos y precios, confirmaciones de citas, recordatorios y seguimiento post-venta. Todo sin necesidad de aumentar tu equipo de atención al cliente.",
      },
    },
  ],
};
---

<Layout
  title="Scalio | Páginas web y automatización para negocios en Perú"
  description="Agencia digital en Lima, Perú. Creamos páginas web que convierten visitantes en clientes y automatizamos tareas repetitivas para tu negocio."
  canonical="/"
  schema={faqSchema}
>
  <TransitionOverlay />
  <Nav />

  <Hero />
  <TrustBar />
  <Services />
  <Diferenciadores />
  <Projects />
  <Testimonials />
  <FAQ />
  <!-- <ContactForm /> -->
  <FinalCTA />

  <Footer />
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      if (typeof gsap === "undefined") return;
      gsap.registerPlugin(ScrollTrigger);

      const sections = [
        { container: ".services-grid", items: ".service-card", y: 50, stagger: 0.12 },
        { container: ".benefits-grid", items: ".benefit-card", y: 40, stagger: 0.1 },
        { container: ".testimonials-grid", items: ".testi", y: 40, stagger: 0.12 },
        { container: ".faq-list", items: ".faq-item", y: 30, stagger: 0.08 },
      ];

      sections.forEach(({ container, items, x, y, stagger }) => {
        const el = document.querySelector(container);
        if (!el) return;

        const from = { opacity: 0 };
        const to = {
          opacity: 1,
          duration: 0.7,
          stagger,
          ease: "expo.out",
        };
        if (x !== undefined) { from.x = x; to.x = 0; }
        if (y !== undefined) { from.y = y; to.y = 0; }

        gsap.fromTo(items, from, {
          scrollTrigger: { trigger: el, start: "top 85%", once: true },
          ...to,
        });
      });

      gsap.fromTo(".faq-cta",
        { opacity: 0, y: 30 },
        {
          scrollTrigger: { trigger: ".faq-cta", start: "top 85%", once: true },
          opacity: 1, y: 0, duration: 0.6, ease: "expo.out",
        },
      );

      gsap.fromTo(".contact-grid",
        { opacity: 0, y: 40 },
        {
          scrollTrigger: { trigger: ".contact-grid", start: "top 85%", once: true },
          opacity: 1, y: 0, duration: 0.8, ease: "expo.out",
        },
      );

      gsap.fromTo(".final-cta-content",
        { opacity: 0, y: 60 },
        {
          scrollTrigger: { trigger: ".final-cta", start: "top 80%", once: true },
          opacity: 1, y: 0, duration: 1, ease: "expo.out",
        },
      );
    });
  </script>
</Layout>
